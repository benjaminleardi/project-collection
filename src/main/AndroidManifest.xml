<?xml version="1.0" encoding="utf-8"?>
<!--
    STARTUP STEP 1: AndroidManifest.xml - App configuration and entry point

    This file is read by Android when the app is installed and launched.
    It declares:
    - Permissions the app needs (INTERNET, ACCESS_NETWORK_STATE)
    - The custom Application class (EventableApplication) that runs first
    - Activities, services, and other components
    - Which activity should launch when the user taps the app icon (MAIN/LAUNCHER)
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Request permission to access the internet (needed for HTTP requests) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Request permission to check network connectivity -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- STARTUP STEP 2: Specify the custom Application class to run on startup -->
    <application
        android:name="edu.illinois.cs.cs124.ay2025.mp.application.EventableApplication"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="Eventable"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        tools:ignore="DataExtractionRules">

        <!-- STARTUP STEP 4: Declare MainActivity as the launcher activity -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="true">
            <!-- This intent filter makes MainActivity the entry point when launching the app -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- EventActivity displays full details of a single event -->
        <activity
            android:name=".activities.EventActivity"
            android:exported="false" />
    </application>
</manifest>
